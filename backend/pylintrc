[MASTER]
ignore=CVS,.git,__pycache__,migrations
jobs=1
persistent=yes

[MESSAGES CONTROL]
disable=C0111,C0113,C0114,C0115,C0116,C0301,C0302,C0303,C0325,C0330,C0333,R0801,R0902,R0903,R0904,R0911,R0912,R0913,R0914,R0915

[REPORTS]
output-format=text
reports=no

[REFACTORING]
max-nested-blocks=5
never-returning-functions=sys.exit,argparse.parse_error

[BASIC]
good-names=i,j,k,ex,Run,_,db,id,pt,fn
argument-naming-style=snake_case
attr-naming-style=snake_case
class-attribute-naming-style=any
class-const-naming-style=UPPER_CASE
class-naming-style=PascalCase
const-naming-style=UPPER_CASE
function-naming-style=snake_case
inlinevar-naming-style=any
method-naming-style=snake_case
module-naming-style=snake_case
variable-naming-style=snake_case

[FORMAT]
indent-after-paren=4
indent-string='    '
max-line-length=120
max-module-lines=1500

[DESIGN]
max-args=8
max-attributes=12
max-bool-as-int=no
max-branches=15
max-locals=20
max-parents=7
max-public-methods=25
max-returns=6
max-statements=60
min-public-methods=1

[IMPORTS]
known-third-party=sqlalchemy,fastapi,pydantic,passlib,jose,bcrypt,element

[MASTER]
extension-pkg-whitelist=pydantic
